{
    "extends": ["config:recommended"],
    "automerge": true,
    "dependencyDashboard": true,
    "pinDigests": true,
    "branchPrefix": "deps/",
    "enabledManagers": ["github-actions"],
    "packageRules": [
        {
            "matchPackageNames": ["*"],
            "groupName": "all dependencies",
            "groupSlug": "all"
        }
    ]
}
